{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "memeover",
  "version": "0.10.1",
  "identifier": "com.simonhazard.memeover",
  "build": {
    "beforeDevCommand": "bun --bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun --bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "settings",
        "title": "MemeOver",
        "width": 960,
        "height": 700,
        "minWidth": 800,
        "minHeight": 560,
        "decorations": true,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: blob: https://cdn.discordapp.com https://media.discordapp.net https://tenor.com https://media.tenor.com https://i.giphy.com; media-src 'self' blob: https://cdn.discordapp.com https://media.discordapp.net https://tenor.com https://media.tenor.com https://i.giphy.com; connect-src 'self' ws: wss: ipc: https://ipc.localhost https://*.simonhazard.com wss://*.simonhazard.com https://api.github.com"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/SimonHazard/MemeOver/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENBN0M3QkI3RkYwRTQ1ODAKUldTQVJRNy90M3Q4eWk2Yy93d1V2eXdJTk5wTEJFeUpObFg5WEJQL3NKSW5LYXZ1cEVybFVwSU8K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
