# ─── Required ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_id

# ─── Optional ─────────────────────────────────────────────────────────────────
# WS_PORT=3001

# BetterStack Logtail — send structured logs to BetterStack (https://betterstack.com/logs)
# If absent, JSON logs go to stdout only (production) or pretty-print (dev).
# LOGTAIL_TOKEN=your_logtail_source_token

# Protect the /metrics endpoint with a bearer token.
# METRICS_TOKEN=your_secret_metrics_token
