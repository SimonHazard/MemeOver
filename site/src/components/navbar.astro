---
import type { Locale } from "@/i18n";
import { getLocalizedPath, t } from "@/i18n";
import MobileMenu from "./mobile-menu.tsx";
import ThemeToggle from "./theme-toggle.tsx";

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const otherLang: Locale = lang === "en" ? "fr" : "en";
const otherLangPath = lang === "en" ? "/fr/" : "/";

const links = [
	{ href: "#features", label: t(lang, "nav.features") },
	{ href: "#download", label: t(lang, "nav.download") },
	{ href: "https://github.com/SimonHazard/MemeOver", label: t(lang, "nav.github") },
];
---

<header class="fixed left-0 right-0 top-0 z-30 border-b-2 border-foreground bg-background/80 backdrop-blur-md">
	<div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
		<!-- Logo -->
		<a
			href={getLocalizedPath(lang, "/")}
			class="flex items-center gap-2 font-display text-xl tracking-wide transition-colors duration-200 hover:text-primary-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
		>
			<img src="/icon.png" alt="MemeOver" width={32} height={32} class="rounded-md" />
			MemeOver
		</a>

		<!-- Desktop nav -->
		<nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
			{links.map((link) => (
				<a
					href={link.href}
					class="font-display text-sm tracking-wide transition-colors duration-200 hover:text-primary-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
					{...(link.href.startsWith("http") ? { target: "_blank", rel: "noopener noreferrer" } : {})}
				>
					{link.label}
				</a>
			))}
		</nav>

		<!-- Actions -->
		<div class="flex items-center gap-3">
			<!-- Language switch -->
			<a
				href={otherLangPath}
				class="inline-flex size-10 items-center justify-center rounded-lg border-2 border-foreground bg-background font-display text-xs uppercase tracking-wide shadow-[2px_2px_0px_0px_var(--nb-shadow)] transition-[background-color,box-shadow,transform] duration-200 hover:bg-accent active:translate-x-0.5 active:translate-y-0.5 active:shadow-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
				aria-label={`Switch to ${otherLang === "fr" ? "Français" : "English"}`}
			>
				{otherLang.toUpperCase()}
			</a>

			<ThemeToggle client:load />

			<!-- Desktop download CTA -->
			<a
				href="#download"
				class="hidden items-center rounded-lg border-2 border-foreground bg-primary px-4 py-2 font-display text-sm tracking-wide text-primary-foreground shadow-[2px_2px_0px_0px_var(--nb-shadow)] transition-[box-shadow,transform] duration-200 hover:shadow-[3px_3px_0px_0px_var(--nb-shadow)] active:translate-x-0.5 active:translate-y-0.5 active:shadow-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background md:inline-flex"
			>
				{t(lang, "nav.download")}
			</a>

			<!-- Mobile menu -->
			<MobileMenu
				client:load
				links={links}
				downloadHref="#download"
				downloadLabel={t(lang, "nav.download")}
			/>
		</div>
	</div>
</header>
