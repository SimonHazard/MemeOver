---
import { Apple, Download, Laptop, PackageOpen } from "lucide-react";
import type { Locale } from "@/i18n";
import { getTranslations } from "@/i18n";

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const dict = getTranslations(lang);

const releaseUrl = "https://github.com/SimonHazard/MemeOver/releases/latest";

const platforms = [
	{
		name: dict.download.windows,
		formats: dict.download.windowsFormats,
		Icon: Laptop,
	},
	{
		name: dict.download.macos,
		formats: dict.download.macosFormats,
		Icon: Apple,
	},
	{
		name: dict.download.linux,
		formats: dict.download.linuxFormats,
		Icon: PackageOpen,
	},
];
---

<section id="download" class="scroll-mt-24 px-4 py-20">
	<div class="mx-auto grid max-w-6xl grid-cols-1 gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
		<div class="flex flex-col gap-4">
			<h2 class="text-balance font-display text-3xl tracking-wide sm:text-4xl">
				{dict.download.title}
			</h2>
			<p class="max-w-xl text-lg text-muted-foreground">
				{dict.download.description}
			</p>
			<a
				href="https://github.com/SimonHazard/MemeOver/releases"
				target="_blank"
				rel="noopener noreferrer"
				class="w-fit font-display text-sm tracking-wide text-muted-foreground underline decoration-foreground/30 underline-offset-4 transition-[color,text-decoration-color] duration-200 hover:text-foreground hover:decoration-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
			>
				{dict.download.allReleases}
			</a>
		</div>

		<div class="rounded-3xl border-2 border-foreground bg-card p-4 shadow-[5px_5px_0px_0px_var(--nb-shadow)] sm:p-5">
			<div class="grid grid-cols-1 gap-3 md:grid-cols-3">
				{platforms.map((platform) => {
					const Icon = platform.Icon;
					return (
						<a
							href={releaseUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="group flex min-h-40 flex-col justify-between rounded-2xl border-2 border-foreground bg-background p-5 shadow-[2px_2px_0px_0px_var(--nb-shadow)] transition-[box-shadow,transform,background-color] duration-200 hover:-translate-y-1 hover:bg-muted hover:shadow-[4px_4px_0px_0px_var(--nb-shadow)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-card"
						>
							<div class="flex items-center justify-between">
								<div class="flex size-12 items-center justify-center rounded-xl border-2 border-foreground bg-primary">
									<Icon className="size-6" aria-hidden="true" />
								</div>
								<Download className="size-5 text-muted-foreground transition-colors duration-200 group-hover:text-foreground" aria-hidden="true" />
							</div>
							<div class="flex flex-col gap-1">
								<span class="font-display text-lg tracking-wide">
									{platform.name}
								</span>
								<span class="font-display text-xs tracking-wide text-muted-foreground">
									{platform.formats}
								</span>
							</div>
						</a>
					);
				})}
			</div>
		</div>
	</div>
</section>
