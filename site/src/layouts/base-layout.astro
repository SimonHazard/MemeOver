---
import "@/styles/global.css";
import { Font } from "astro:assets";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar.astro";
import { getLangFromUrl, t } from "@/i18n";

interface Props {
	title?: string;
	description?: string;
	noindex?: boolean;
}

const lang = getLangFromUrl(Astro.url);
const { title, description, noindex = false } = Astro.props;
const pageTitle = title ?? t(lang, "meta.title");
const pageDescription = description ?? t(lang, "meta.description");
const pageKeywords = t(lang, "meta.keywords");
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/icon.png", Astro.site);
const englishUrl = new URL("/", Astro.site);
const frenchUrl = new URL("/fr/", Astro.site);
const githubUrl = "https://github.com/SimonHazard/MemeOver";
const releaseUrl = "https://github.com/SimonHazard/MemeOver/releases/latest";
const locale = lang === "fr" ? "fr_FR" : "en_US";
const alternateLocale = lang === "fr" ? "en_US" : "fr_FR";
const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "SoftwareApplication",
		name: "MemeOver",
		alternateName: "Meme Over",
		url: englishUrl.toString(),
		description: pageDescription,
		applicationCategory: "EntertainmentApplication",
		operatingSystem: "Windows, macOS, Linux",
		isAccessibleForFree: true,
		license: "https://github.com/SimonHazard/MemeOver/blob/main/LICENSE",
		downloadUrl: releaseUrl,
		codeRepository: githubUrl,
		inLanguage: ["en", "fr"],
		image: ogImage.toString(),
		author: {
			"@type": "Person",
			name: "Simon Hazard",
			url: "https://www.simonhazard.com/",
		},
		offers: {
			"@type": "Offer",
			price: "0",
			priceCurrency: "USD",
			url: releaseUrl,
		},
		sameAs: [githubUrl, "https://www.simonhazard.com/"],
	},
	{
		"@context": "https://schema.org",
		"@type": "WebSite",
		name: "MemeOver",
		alternateName: "Meme Over",
		url: englishUrl.toString(),
		inLanguage: ["en", "fr"],
		publisher: {
			"@type": "Person",
			name: "Simon Hazard",
		},
	},
];
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />

		<!-- Anti-FOUC: apply dark mode before any rendering -->
		<script is:inline>
			(function () {
				const theme = localStorage.getItem("theme");
				if (
					theme === "dark" ||
					(!theme && window.matchMedia("(prefers-color-scheme: dark)").matches)
				) {
					document.documentElement.classList.add("dark");
				}
			})();
		</script>

		<!-- SEO -->
		<title>{pageTitle}</title>
		<meta name="description" content={pageDescription} />
		<meta name="keywords" content={pageKeywords} />
		<meta name="author" content="Simon Hazard" />
		<meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
		<meta name="theme-color" content="#f8c63d" />
		<link rel="canonical" href={canonicalUrl} />
		{!noindex && (
			<>
				<link rel="alternate" hreflang="en" href={englishUrl} />
				<link rel="alternate" hreflang="fr" href={frenchUrl} />
				<link rel="alternate" hreflang="x-default" href={englishUrl} />
			</>
		)}

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="MemeOver" />
		<meta property="og:locale" content={locale} />
		<meta property="og:locale:alternate" content={alternateLocale} />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Favicon -->
		<link rel="icon" type="image/png" href="/icon.png" />
		<link rel="apple-touch-icon" href="/icon.png" />

		{!noindex && (
			<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
		)}

		<!-- Fonts (self-hosted via Astro Fonts API — no third-party CDN) -->
		<Font cssVariable="--display-family" preload />
		<Font cssVariable="--text-family" preload />
	</head>
	<body class="bg-background text-foreground font-sans antialiased">
		<a
			href="#content"
			class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-40 focus:rounded-lg focus:border-2 focus:border-foreground focus:bg-background focus:px-4 focus:py-2 focus:font-display focus:text-sm focus:shadow-[2px_2px_0px_0px_var(--nb-shadow)]"
		>
			Skip to content
		</a>
		<Navbar lang={lang} />
		<main id="content">
			<slot />
		</main>
		<Footer lang={lang} />
	</body>
</html>
